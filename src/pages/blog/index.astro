---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog — dpaul256" description="Posts and notes">
  <section class="card">
    <h1 style="margin-top:0;">Blog</h1>
    <p class="muted">Notes, projects, and things I’m learning.</p>
  </section>

  <div class="postList">
  {posts.map((post) => (
    <a class="postCard" href={`${import.meta.env.BASE_URL}blog/${post.slug}/`}>
      <div class="postMeta">
        <time class="muted">{post.data.date.toLocaleDateString()}</time>
        {post.data.tags?.length ? (
          <span class="muted"> · {post.data.tags.join(" · ")}</span>
        ) : null}
      </div>

      <h2 class="postTitle">{post.data.title}</h2>

      <p class="postPreview">
        {post.data.excerpt ?? post.data.description ?? "No preview available yet."}
      </p>

      <div class="postActions">
        <span class="readMore">Read more →</span>
      </div>
    </a>
  ))}
</div>

<style>
  .postList { margin-top: 18px; display: grid; gap: 14px; }
  .postCard{
    display:block;
    border: 1px solid rgba(127,127,127,.25);
    border-radius: 16px;
    padding: 16px;
    background: rgba(127,127,127,.06);

    /* 👇 這三行就是「內容不像連結」的關鍵 */
    color: inherit;
    text-decoration: none;
  }

  .postCard:hover{
    border-color: rgba(127,127,127,.45);
    background: rgba(127,127,127,.10);
    transform: translateY(-1px);
  }

  /* 保險：就算裡面有別的元素也不要底線 */
  .postCard :global(*) {
    text-decoration: none;
  }
  .postMeta { font-size: 14px; margin-bottom: 8px; }
  .postTitle { margin: 0 0 8px 0; }
  .postPreview { margin: 0; opacity: .85; }
  .postActions{
  margin-top: 12px;
  display: flex;
  justify-content: flex-end; /* 靠右 */
}

.readMore{
  color: inherit;
  text-decoration: none;
  opacity: .9;
}
</style>
</BaseLayout>