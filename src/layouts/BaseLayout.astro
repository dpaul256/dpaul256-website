---
const base = import.meta.env.BASE_URL;
const { title = "My Site", description = "Personal website & blog" } = Astro.props;
const pathname = Astro.url.pathname;

const nav = [
  { href: base, label: "Home" },
  { href: `${base}/blog`, label: "Blog" },
  { href: `${base}/about`, label: "About" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      /* ✅ 告訴瀏覽器：本頁就是 Dark UI */
      :root { color-scheme: dark; }

      body {
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        margin: 0;
        line-height: 1.6;

        /* ✅ 永遠黑底白字 */
        background: #000;
        color: #fff;
      }

      /* links 不要變藍色 */
      a { text-decoration: none; color: inherit; }

      .container { max-width: 980px; margin: 0 auto; padding: 24px; }

      header {
        position: sticky;
        top: 0;
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(255,255,255,.18);
        background: rgba(0,0,0,.6); /* 避免不同瀏覽器 blur 顯示不一致 */
      }

      nav { display: flex; gap: 14px; align-items: center; justify-content: space-between; }
      .links { display: flex; gap: 12px; }

      .links a { padding: 8px 10px; border-radius: 10px; }
      .links a[aria-current="page"] { background: rgba(255,255,255,.12); }

      main { padding-top: 18px; }

      .card {
        border: 1px solid rgba(255,255,255,.18);
        border-radius: 16px;
        padding: 16px;
      }

      footer { margin-top: 36px; opacity: .85; font-size: 14px; }
      .muted { opacity: .75; }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <div><strong>dpaul256</strong> <span class="muted">/ blog</span></div>
          <div class="links">
            {nav.map((item) => (
              <a href={item.href} aria-current={pathname === item.href ? "page" : undefined}>
                {item.label}
              </a>
            ))}
          </div>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="container">
      <div>© {new Date().getFullYear()} dpaul256 · Built with Astro</div>
    </footer>
  </body>
</html>